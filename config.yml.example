# rcoder 配置文件示例
# 复制此文件为 config.yml 并修改配置

# 默认使用的 AI 代理类型
# 可选值: "Codex", "Claude" 
# Codex: 使用 OpenAI Codex 代理
# Claude: 使用 Anthropic Claude Code 代理
default_agent: Codex

# 项目工作的根目录
# 相对路径基于启动 rcoder 的当前目录
# 绝对路径也可以使用，例如: "/Users/username/projects"
projects_dir: "./project_workspace"

# 服务端口
# 环境变量 RCODER_PORT 可以覆盖此设置
# 例如: RCODER_PORT=8080 cargo run
port: 3000