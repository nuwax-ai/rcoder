# RCoder Docker 测试环境变量模板
# 复制此文件为 .env 并填入真实值
# .env 文件已被 .gitignore 忽略，不会提交到 Git

# ============================================
# 环境切换配置
# ============================================
# 选择使用的远程环境: test (测试环境) 或 prod (生产环境)
# 脚本会根据此变量自动选择对应的配置
export REMOTE_ENV=test

# ============================================
# 测试脚本使用的 API Key
# ============================================
# 模型提供商 API Key (智谱等)
export TEST_API_KEY=your_model_provider_api_key_here

# RCoder 服务自身的 API Key 鉴权（可选，默认关闭）
export RCODER_API_KEY=sk-your-rcoder-api-key-here

# ============================================
# 测试环境 (REMOTE_ENV=test 时使用)
# ============================================
# 测试环境 - 远程服务器地址
export REMOTE_TEST_HOST=your_test_host_ip
# 测试环境 - 远程服务器 SSH 用户名
export REMOTE_TEST_USER=your_test_username
# 测试环境 - 远程服务器 SSH 密码
export REMOTE_TEST_PASS=your_test_password
# 测试环境 - 远程服务器 API 端口
export REMOTE_TEST_API_PORT=8086
# 测试环境 - 远程主容器 ID（用于重启服务脚本）
export REMOTE_TEST_MAIN_CONTAINER=your_test_container_id
# 测试环境 - 主服务日志文件路径（支持日期格式，如 rcoder.2026-01-12）
export REMOTE_TEST_MAIN_LOG_PATH=/home/test_user/docker/logs/rcoder/rcoder.2026-01-12
# 测试环境 - 容器日志目录路径
export REMOTE_TEST_CONTAINER_LOG_DIR=/home/test_user/docker/logs/rcoder/container

# ============================================
# 生产环境 (REMOTE_ENV=prod 时使用)
# ============================================
# 生产环境 - 远程服务器地址
export REMOTE_PROD_HOST=your_prod_host_ip
# 生产环境 - 远程服务器 SSH 用户名
export REMOTE_PROD_USER=your_prod_username
# 生产环境 - 远程服务器 SSH 密码
export REMOTE_PROD_PASS=your_prod_password
# 生产环境 - 远程服务器 API 端口
export REMOTE_PROD_API_PORT=8086
# 生产环境 - 远程主容器 ID（用于重启服务脚本）
export REMOTE_PROD_MAIN_CONTAINER=your_prod_container_id
# 生产环境 - 主服务日志文件路径（支持日期格式，如 rcoder.2026-01-12）
export REMOTE_PROD_MAIN_LOG_PATH=/home/prod_user/docker/logs/rcoder/rcoder.2026-01-12
# 生产环境 - 容器日志目录路径
export REMOTE_PROD_CONTAINER_LOG_DIR=/home/prod_user/docker/logs/rcoder/container

# ============================================
# 兼容性配置（向后兼容，如果设置了这些变量，将优先使用）
# 如果未设置 REMOTE_ENV 或需要覆盖环境特定配置，可以使用以下变量
# ============================================
# export REMOTE_HOST=your_remote_host_ip
# export REMOTE_USER=your_username
# export REMOTE_PASS=your_password
# export REMOTE_API_PORT=8086
# export REMOTE_MAIN_CONTAINER=your_container_id
# export MAIN_LOG_PATH=/home/user/docker/logs/rcoder/rcoder.2026-01-12
# export CONTAINER_LOG_DIR=/home/user/docker/logs/rcoder/container
